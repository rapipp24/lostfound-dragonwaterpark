generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
}

// 1. Tabel Pengguna (Member & Admin)
model User {
  id        Int      @id @default(autoincrement())
  nama      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  // (foreign key)
  roleId Int
  
  // Relasi: Satu user bisa punya banyak laporan dan banyak klaim
  role Role @relation(fields: [roleId], references: [roleId])
  reports   Report[]
  claims    Claim[]
}

// 2. Tabel Laporan Barang (Hilang/Temukan)
model Report {
  id            Int      @id @default(autoincrement())
  judul         String
  deskripsi     String?
  lokasi        String
  fotoUrl       String?  // Tanda tanya (?) artinya boleh kosong
  status        String   @default("PENDING") // PENDING, CLAIMED, COMPLETED
  type          String   // LOST atau FOUND
  createdAt     DateTime @default(now())
  
  // Relasi: Laporan ini milik siapa?
  userId        Int
  reporter      User     @relation(fields: [userId], references: [id])
  
  // Relasi: Satu laporan bisa punya banyak klaim
  claims        Claim[]
}

// 3. Tabel Klaim (Proses pengambilan barang)
model Claim {
  id              Int      @id @default(autoincrement())
  buktiDeskripsi  String
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt       DateTime @default(now())
  
  // Relasi: Siapa yang klaim?
  userId          Int
  claimant        User     @relation(fields: [userId], references: [id])
  
  // Relasi: Barang mana yang diklaim?
  reportId        Int
  report          Report   @relation(fields: [reportId], references: [id])
}

// 4. Tabel role
model Role {
  roleId Int @id @default(autoincrement())
  namaRole String @unique

  // relasi: satu role bisa dimiliki banyak 
 users User[]
}
